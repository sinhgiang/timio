generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  timezone    String    @default("Asia/Ho_Chi_Minh")
  plan        String    @default("starter")
  planExpires DateTime?
  kioskMessages   String? // JSON: { welcome, checkinOntime, checkinLate, checkout }
  customOptions   String? // JSON: { departments: string[], positions: string[] }
  telegramBotToken String? // Telegram bot token for notifications
  accountingChatId String? // Telegram chat ID cho kế toán (nhận thông báo duyệt nghỉ phép)
  zaloOaToken      String? // Zalo Official Account access token
  overtimeRates   String? // JSON: { weekday: 1.5, weekend: 2.0, holiday: 3.0 }
  signatureUrl    String? // base64 ảnh chữ ký admin
  stampUrl        String? // base64 ảnh dấu công ty
  referredBy      String? // slug của công ty đã giới thiệu mình
  affiliateCode   String? // code của affiliate partner đã giới thiệu
  paydayOfMonth   Int     @default(5) // ngày phát lương hàng tháng (1-31)
  createdAt   DateTime  @default(now())

  branches      Branch[]
  employees     Employee[]
  penaltyRules  PenaltyRule[]
  rewardRules   RewardRule[]
  admins        Admin[]
  holidays      Holiday[]
  leaveRequests LeaveRequest[]
  payments         Payment[]
  impersonationLogs ImpersonationLog[]
  salaryPayments   SalaryPayment[]
  salaryAdvances   SalaryAdvance[]
  shiftAssignments ShiftAssignment[]
}

model Admin {
  id        String   @id @default(cuid())
  companyId String
  email     String   @unique
  name      String
  password  String?
  role      String   @default("owner") // "owner" | "manager" | "accountant"
  branchId  String?  // null = xem toàn công ty, có value = chỉ xem chi nhánh này
  receiveLeaveEmail Boolean @default(true)
  receiveTelegram   Boolean @default(false)
  telegramChatId    String?
  receiveZalo       Boolean @default(false)
  zaloUserId        String? // Zalo user ID (người dùng phải follow OA trước)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch  Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
}

model Branch {
  id           String  @id @default(cuid())
  companyId    String
  name         String
  checkInTime  String  @default("07:30")
  checkOutTime String  @default("17:30")
  gracePeriod  Int     @default(5)
  workDays     String  @default("1,2,3,4,5")
  telegramChatId    String?
  lat               Float?
  lng               Float?
  gpsRadius         Int     @default(200)
  standardWorkDays  Int     @default(26)
  allowedIPs        String? // JSON: ["1.2.3.4","10.0.0.0/8"] — danh sách IP được phép check-in
  createdAt    DateTime @default(now())

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
  logs      AttendanceLog[]
  admins    Admin[]
}

model Employee {
  id         String  @id @default(cuid())
  companyId  String
  branchId   String
  name       String
  code       String
  pin        String
  department String?
  position        String?
  status          String  @default("active")
  faceDescriptors String? // JSON: number[][]  — stored face embeddings
  shiftOverride   String? // JSON: {checkInTime, checkOutTime, workDays, gracePeriod} — overrides branch defaults
  email               String?   // Email cá nhân (nhận phiếu lương)
  avatarUrl           String?   // base64 ảnh đại diện
  phone               String?   // Số điện thoại
  cccd                String?   // Căn cước công dân
  baseSalary          Int?      @default(0)
  joinDate            DateTime?
  dateOfBirth         String?   // YYYY-MM-DD
  annualLeaveBalance  Float     @default(12) // ngày phép năm còn lại
  dependents          Int       @default(0)  // số người phụ thuộc (giảm trừ thuế TNCN)
  bankName            String?   // Tên ngân hàng (VCB, TCB, MB, ...)
  bankAccount         String?   // Số tài khoản
  bankBranch          String?   // Chi nhánh ngân hàng
  qrToken             String?   @unique // Token ngẫu nhiên để check-in bằng QR code
  createdAt           DateTime  @default(now())

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch              Branch               @relation(fields: [branchId], references: [id])
  logs                AttendanceLog[]
  summaries           MonthlySummary[]
  leaveRequests       LeaveRequest[]
  correctionRequests  CorrectionRequest[]
  contracts           Contract[]
  salaryPayments      SalaryPayment[]
  salaryAdvances      SalaryAdvance[]
  shiftAssignments    ShiftAssignment[]

  @@unique([companyId, code])
}

model Contract {
  id          String    @id @default(cuid())
  employeeId  String
  type        String    @default("fixed_term") // "probation" | "fixed_term" | "indefinite" | "seasonal" | "part_time"
  startDate   String    // YYYY-MM-DD
  endDate     String?   // YYYY-MM-DD — null nếu không thời hạn
  note        String?
  fileUrl     String?   // URL hoặc base64 của file hợp đồng scan
  fileName    String?   // Tên file gốc
  createdAt   DateTime  @default(now())

  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AttendanceLog {
  id            String    @id @default(cuid())
  employeeId    String
  branchId      String
  date          String
  checkInAt     DateTime?
  checkOutAt    DateTime?
  minutesLate     Int       @default(0)
  status          String    @default("absent")
  penaltyAmount   Int       @default(0)
  minutesOvertime  Int       @default(0)
  overtimeAmount   Int       @default(0)
  overtimeStatus   String    @default("none") // "none" | "pending" | "approved" | "rejected"
  note             String?
  createdAt       DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@unique([employeeId, date])
}

model MonthlySummary {
  id               String @id @default(cuid())
  employeeId       String
  year             Int
  month            Int
  daysPresent      Int    @default(0)
  daysLate         Int    @default(0)
  daysAbsent       Int    @default(0)
  totalMinutesLate    Int    @default(0)
  totalPenalty        Int    @default(0)
  totalReward         Int    @default(0)
  totalMinutesOvertime Int   @default(0)
  totalOvertimeAmount  Int   @default(0)
  updatedAt           DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, month])
}

model PenaltyRule {
  id          String @id @default(cuid())
  companyId   String
  fromMinutes Int
  toMinutes   Int
  amount      Int
  type        String @default("late")  // "late" | "early_leave"

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model RewardRule {
  id        String @id @default(cuid())
  companyId String
  condition String
  amount    Int
  label     String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Holiday {
  id         String  @id @default(cuid())
  companyId  String
  date       String  // YYYY-MM-DD
  name       String
  isNational Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  companyId  String
  type       String   @default("annual") // "annual" | "sick" | "unpaid" | "maternity" | "other"
  fromDate   String   // YYYY-MM-DD
  toDate     String   // YYYY-MM-DD
  days       Float
  reason     String?
  status     String   @default("pending") // "pending" | "approved" | "rejected"
  note       String?  // ghi chú của sếp khi duyệt/từ chối
  handoverEmployeeId   String?  // người nhận việc
  handoverConfirmedAt  DateTime? // thời điểm người nhận xác nhận
  employeeSignature    String?  // base64 PNG chữ ký nhân viên từ kiosk
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AttendanceCorrection {
  id         String   @id @default(cuid())
  logId      String
  adminId    String
  field      String   // "checkInAt" | "checkOutAt" | "status"
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())
}

// Nhân viên xin điều chỉnh chấm công (quên chấm, sai giờ)
model CorrectionRequest {
  id                String   @id @default(cuid())
  employeeId        String
  date              String   // YYYY-MM-DD
  type              String   @default("check_in") // "check_in" | "check_out" | "both"
  requestedCheckIn  String?  // HH:MM — giờ vào đề nghị
  requestedCheckOut String?  // HH:MM — giờ ra đề nghị
  reason            String
  status            String   @default("pending") // "pending" | "approved" | "rejected"
  adminNote         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model Payment {
  id        String    @id @default(cuid())
  companyId String
  reference String    @unique  // e.g., TIMIO_ABC123
  amount    Int                // VND
  plan      String             // "pro"
  months    Int       @default(1)
  status    String    @default("pending") // pending | completed | expired
  paidAt    DateTime?
  expiresAt DateTime           // payment link expires after 2 hours
  createdAt DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ImpersonationLog {
  id         String   @id @default(cuid())
  adminEmail String
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  action     String   // "enter" | "exit"
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([createdAt(sort: Desc)])
}

model Affiliate {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  code        String   @unique  // unique affiliate code, used in ?aff=CODE links
  phone       String?
  channel     String?           // "blog", "youtube", "zalo", "facebook", etc.
  status      String   @default("pending") // "pending" | "active"
  bankName    String?           // Tên ngân hàng (VCB, TCB, MB, ...)
  bankAccount String?           // Số tài khoản ngân hàng
  accountName String?           // Tên chủ tài khoản (đúng như CCCD)
  otp         String?           // 6-digit OTP code (hashed)
  otpExpiresAt DateTime?        // OTP expires after 15 minutes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clicks        AffiliateClick[]
  codeHistories AffiliateCodeHistory[]
}

model AffiliateClick {
  id            String    @id @default(cuid())
  affiliateCode String
  affiliate     Affiliate @relation(fields: [affiliateCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  ip            String?
  userAgent     String?
  referrer      String?   // full referrer URL
  device        String?   // "mobile" | "desktop" | "tablet"
  convertedAt   DateTime? // when they registered as a company
  companyId     String?   // which company they became (after registration)
  createdAt     DateTime  @default(now())

  @@index([affiliateCode])
  @@index([createdAt(sort: Desc)])
}

model SalaryPayment {
  id          String    @id @default(cuid())
  companyId   String
  employeeId  String
  year        Int
  month       Int
  amount      Float     @default(0)
  paidAt      DateTime?
  status      String    @default("unpaid") // "unpaid" | "paid"
  note        String?
  createdAt   DateTime  @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, month])
  @@index([companyId, year, month])
}

model SalaryAdvance {
  id          String    @id @default(cuid())
  companyId   String
  employeeId  String
  year        Int
  month       Int
  amount      Int
  note        String?
  status      String    @default("pending") // "pending" | "approved" | "rejected"
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, year, month])
  @@index([employeeId])
}

model ShiftAssignment {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  date       String   // YYYY-MM-DD
  shiftLabel String   // "Ca sáng" | "Ca chiều" | "Ca tối" | "Ca cả ngày" | "Nghỉ" | custom
  checkIn    String   // HH:MM
  checkOut   String   // HH:MM
  note       String?
  createdAt  DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([companyId, date])
}

// Lưu các code cũ khi affiliate đổi slug — old links vẫn tracking được
model AffiliateCodeHistory {
  id          String    @id @default(cuid())
  affiliateId String
  oldCode     String    @unique
  createdAt   DateTime  @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
}
