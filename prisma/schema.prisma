generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  timezone    String    @default("Asia/Ho_Chi_Minh")
  plan        String    @default("starter")
  planExpires DateTime?
  kioskMessages   String? // JSON: { welcome, checkinOntime, checkinLate, checkout }
  customOptions   String? // JSON: { departments: string[], positions: string[] }
  telegramBotToken String? // Telegram bot token for notifications
  accountingChatId String? // Telegram chat ID cho kế toán (nhận thông báo duyệt nghỉ phép)
  zaloOaToken      String? // Zalo Official Account access token
  overtimeRates   String? // JSON: { weekday: 1.5, weekend: 2.0, holiday: 3.0 }
  signatureUrl    String? // base64 ảnh chữ ký admin
  stampUrl        String? // base64 ảnh dấu công ty
  referredBy      String? // slug của công ty đã giới thiệu mình
  affiliateCode   String? // code của affiliate partner đã giới thiệu
  paydayOfMonth   Int     @default(5) // ngày phát lương hàng tháng (1-31)
  trialEndsAt     DateTime? // null = không dùng thử / đã trả tiền
  createdAt   DateTime  @default(now())

  branches      Branch[]
  employees     Employee[]
  penaltyRules  PenaltyRule[]
  rewardRules   RewardRule[]
  admins        Admin[]
  holidays      Holiday[]
  leaveRequests LeaveRequest[]
  payments         Payment[]
  impersonationLogs ImpersonationLog[]
  salaryPayments   SalaryPayment[]
  salaryAdvances   SalaryAdvance[]
  shiftAssignments  ShiftAssignment[]
  shiftSwapRequests ShiftSwapRequest[]
  overtimeRequests  OvertimeRequest[]
  auditLogs         AuditLog[]
  disciplineRecords   DisciplineRecord[]
  assets              Asset[]
  workHistories       WorkHistory[]
  certificates        Certificate[]
  salaryHistories     SalaryHistory[]
  earlyLeaveRequests  EarlyLeaveRequest[]
  salesRecords        SalesRecord[]
  jobPostings         JobPosting[]
  candidates          Candidate[]
  announcements       Announcement[]
  expenseClaims       ExpenseClaim[]
  performanceReviews  PerformanceReview[]
  checklistTemplates  ChecklistTemplate[]
  employeeChecklists  EmployeeChecklist[]
  shiftTemplates      ShiftTemplate[]
}

model Admin {
  id        String   @id @default(cuid())
  companyId String
  email     String   @unique
  name      String
  password  String?
  role      String   @default("owner") // "owner" | "manager" | "accountant"
  branchId  String?  // null = xem toàn công ty, có value = chỉ xem chi nhánh này
  receiveLeaveEmail Boolean @default(true)
  receiveTelegram   Boolean @default(false)
  telegramChatId    String?
  receiveZalo       Boolean @default(false)
  zaloUserId        String? // Zalo user ID (người dùng phải follow OA trước)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch  Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
}

model Branch {
  id           String  @id @default(cuid())
  companyId    String
  name         String
  checkInTime  String  @default("07:30")
  checkOutTime String  @default("17:30")
  gracePeriod  Int     @default(5)
  workDays     String  @default("1,2,3,4,5")
  telegramChatId    String?
  lat               Float?
  lng               Float?
  gpsRadius         Int     @default(200)
  standardWorkDays  Int     @default(26)
  allowedIPs        String? // JSON: ["1.2.3.4","10.0.0.0/8"] — danh sách IP được phép check-in
  createdAt    DateTime @default(now())

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
  logs      AttendanceLog[]
  admins    Admin[]
}

model Employee {
  id         String  @id @default(cuid())
  companyId  String
  branchId   String
  name       String
  code       String
  pin        String
  department String?
  position        String?
  status          String  @default("active")
  faceDescriptors String? // JSON: number[][]  — stored face embeddings
  shiftOverride   String? // JSON: {checkInTime, checkOutTime, workDays, gracePeriod} — overrides branch defaults
  email               String?   // Email cá nhân (nhận phiếu lương)
  avatarUrl           String?   // base64 ảnh đại diện
  phone               String?   // Số điện thoại
  cccd                String?   // Căn cước công dân
  baseSalary          Int?      @default(0)
  joinDate            DateTime?
  dateOfBirth         String?   // YYYY-MM-DD
  annualLeaveBalance  Float     @default(12) // ngày phép năm còn lại
  leaveCarryForward   Float     @default(0)  // ngày phép chuyển từ năm trước
  dependents          Int       @default(0)  // số người phụ thuộc (giảm trừ thuế TNCN)
  bankName            String?   // Tên ngân hàng (VCB, TCB, MB, ...)
  bankAccount         String?   // Số tài khoản
  bankBranch          String?   // Chi nhánh ngân hàng
  qrToken             String?   @unique // Token ngẫu nhiên để check-in bằng QR code
  allowancesJson      String?   // JSON: [{label: "Xăng xe", amount: 500000}]
  salaryType          String    @default("fixed") // "fixed" | "commission" | "kpi" | "hybrid"
  commissionRate      Float?    // % hoa hồng trên doanh số (dùng khi salaryType=commission/hybrid)
  kpiTarget           Float?    // Mục tiêu KPI/tháng (điểm hoặc doanh số)
  kpiBonus            Float?    // Thưởng cố định khi đạt 100% KPI
  createdAt           DateTime  @default(now())

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch              Branch               @relation(fields: [branchId], references: [id])
  logs                AttendanceLog[]
  summaries           MonthlySummary[]
  leaveRequests       LeaveRequest[]
  correctionRequests  CorrectionRequest[]
  contracts           Contract[]
  salaryPayments      SalaryPayment[]
  salaryAdvances      SalaryAdvance[]
  shiftAssignments          ShiftAssignment[]
  swapRequestsAsRequester   ShiftSwapRequest[] @relation("SwapRequester")
  swapRequestsAsTarget      ShiftSwapRequest[] @relation("SwapTarget")
  overtimeRequests          OvertimeRequest[]
  disciplineRecords   DisciplineRecord[]
  assets              Asset[]
  workHistories       WorkHistory[]
  certificates        Certificate[]
  salaryHistories     SalaryHistory[]
  earlyLeaveRequests  EarlyLeaveRequest[]
  salesRecords        SalesRecord[]
  candidatesApplied   Candidate[]
  expenseClaims       ExpenseClaim[]
  performanceReviews  PerformanceReview[]
  employeeChecklists  EmployeeChecklist[]

  @@unique([companyId, code])
}

model Contract {
  id          String    @id @default(cuid())
  employeeId  String
  type        String    @default("fixed_term") // "probation" | "fixed_term" | "indefinite" | "seasonal" | "part_time"
  startDate   String    // YYYY-MM-DD
  endDate     String?   // YYYY-MM-DD — null nếu không thời hạn
  note        String?
  fileUrl     String?   // URL hoặc base64 của file hợp đồng scan
  fileName    String?   // Tên file gốc
  createdAt   DateTime  @default(now())

  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AttendanceLog {
  id            String    @id @default(cuid())
  employeeId    String
  branchId      String
  date          String
  checkInAt     DateTime?
  checkOutAt    DateTime?
  minutesLate     Int       @default(0)
  status          String    @default("absent")
  penaltyAmount   Int       @default(0)
  minutesOvertime  Int       @default(0)
  overtimeAmount   Int       @default(0)
  overtimeStatus   String    @default("none") // "none" | "pending" | "approved" | "rejected"
  note             String?
  createdAt       DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@unique([employeeId, date])
}

model MonthlySummary {
  id               String @id @default(cuid())
  employeeId       String
  year             Int
  month            Int
  daysPresent      Int    @default(0)
  daysLate         Int    @default(0)
  daysAbsent       Int    @default(0)
  totalMinutesLate    Int    @default(0)
  totalPenalty        Int    @default(0)
  totalReward         Int    @default(0)
  totalMinutesOvertime Int   @default(0)
  totalOvertimeAmount  Int   @default(0)
  updatedAt           DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, month])
}

model PenaltyRule {
  id          String @id @default(cuid())
  companyId   String
  fromMinutes Int
  toMinutes   Int
  amount      Int
  type        String @default("late")  // "late" | "early_leave"

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model RewardRule {
  id        String @id @default(cuid())
  companyId String
  condition String
  amount    Int
  label     String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Holiday {
  id         String  @id @default(cuid())
  companyId  String
  date       String  // YYYY-MM-DD
  name       String
  isNational Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  companyId  String
  type       String   @default("annual") // "annual" | "sick" | "unpaid" | "maternity" | "other"
  fromDate   String   // YYYY-MM-DD
  toDate     String   // YYYY-MM-DD
  days       Float
  reason     String?
  status     String   @default("pending") // "pending" | "approved" | "rejected"
  note       String?  // ghi chú của sếp khi duyệt/từ chối
  handoverEmployeeId   String?  // người nhận việc
  handoverConfirmedAt  DateTime? // thời điểm người nhận xác nhận
  employeeSignature    String?  // base64 PNG chữ ký nhân viên từ kiosk
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AttendanceCorrection {
  id         String   @id @default(cuid())
  logId      String
  adminId    String
  field      String   // "checkInAt" | "checkOutAt" | "status"
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())
}

// Nhân viên xin điều chỉnh chấm công (quên chấm, sai giờ)
model CorrectionRequest {
  id                String   @id @default(cuid())
  employeeId        String
  date              String   // YYYY-MM-DD
  type              String   @default("check_in") // "check_in" | "check_out" | "both"
  requestedCheckIn  String?  // HH:MM — giờ vào đề nghị
  requestedCheckOut String?  // HH:MM — giờ ra đề nghị
  reason            String
  status            String   @default("pending") // "pending" | "approved" | "rejected"
  adminNote         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model Payment {
  id        String    @id @default(cuid())
  companyId String
  reference String    @unique  // e.g., TIMIO_ABC123
  amount    Int                // VND
  plan      String             // "pro"
  months    Int       @default(1)
  status    String    @default("pending") // pending | completed | expired
  paidAt    DateTime?
  expiresAt DateTime           // payment link expires after 2 hours
  createdAt DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ImpersonationLog {
  id         String   @id @default(cuid())
  adminEmail String
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  action     String   // "enter" | "exit"
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([createdAt(sort: Desc)])
}

model Affiliate {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  code        String   @unique  // unique affiliate code, used in ?aff=CODE links
  phone       String?
  channel     String?           // "blog", "youtube", "zalo", "facebook", etc.
  status      String   @default("pending") // "pending" | "active"
  bankName    String?           // Tên ngân hàng (VCB, TCB, MB, ...)
  bankAccount String?           // Số tài khoản ngân hàng
  accountName String?           // Tên chủ tài khoản (đúng như CCCD)
  otp         String?           // 6-digit OTP code (hashed)
  otpExpiresAt DateTime?        // OTP expires after 15 minutes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clicks        AffiliateClick[]
  codeHistories AffiliateCodeHistory[]
}

model AffiliateClick {
  id            String    @id @default(cuid())
  affiliateCode String
  affiliate     Affiliate @relation(fields: [affiliateCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  ip            String?
  userAgent     String?
  referrer      String?   // full referrer URL
  device        String?   // "mobile" | "desktop" | "tablet"
  convertedAt   DateTime? // when they registered as a company
  companyId     String?   // which company they became (after registration)
  createdAt     DateTime  @default(now())

  @@index([affiliateCode])
  @@index([createdAt(sort: Desc)])
}

model SalaryPayment {
  id          String    @id @default(cuid())
  companyId   String
  employeeId  String
  year        Int
  month       Int
  amount      Float     @default(0)
  paidAt      DateTime?
  status      String    @default("unpaid") // "unpaid" | "paid"
  note        String?
  createdAt   DateTime  @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, month])
  @@index([companyId, year, month])
}

model SalaryAdvance {
  id          String    @id @default(cuid())
  companyId   String
  employeeId  String
  year        Int
  month       Int
  amount      Int
  note        String?
  status      String    @default("pending") // "pending" | "approved" | "rejected"
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, year, month])
  @@index([employeeId])
}

model ShiftAssignment {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  date       String   // YYYY-MM-DD
  shiftLabel String   // "Ca sáng" | "Ca chiều" | "Ca tối" | "Ca cả ngày" | "Nghỉ" | custom
  checkIn    String   // HH:MM
  checkOut   String   // HH:MM
  note       String?
  createdAt  DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, date])
  @@index([companyId, date])
}

model OvertimeRequest {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  date       String   // YYYY-MM-DD — ngày muốn tăng ca
  startTime  String   // HH:MM
  endTime    String   // HH:MM
  hours      Float    // số giờ dự kiến
  reason     String?
  status     String   @default("pending") // pending | approved | rejected
  note       String?  // ghi chú của admin khi duyệt
  createdAt  DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([employeeId])
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  adminId    String?
  adminEmail String?
  action     String   // "create_employee" | "approve_leave" | "reject_leave" | "update_salary" | ...
  entityType String?  // "Employee" | "LeaveRequest" | "AttendanceLog" | ...
  entityId   String?
  detail     String?  // JSON chi tiết
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, action])
}

model DisciplineRecord {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  type       String   // "warning" | "serious_warning" | "suspension" | "dismissal"
  date       String   // YYYY-MM-DD
  reason     String
  note       String?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([companyId])
  @@index([employeeId])
}

model Asset {
  id          String    @id @default(cuid())
  companyId   String
  code        String
  name        String
  category    String?   // "laptop" | "phone" | "vehicle" | "key" | "card" | "other"
  employeeId  String?
  assignedAt  DateTime?
  returnedAt  DateTime?
  status      String    @default("available") // "available" | "assigned" | "damaged" | "lost"
  note        String?
  createdAt   DateTime  @default(now())
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  @@index([companyId, status])
  @@index([employeeId])
}

model WorkHistory {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  date        String   // YYYY-MM-DD
  type        String   // "promotion" | "transfer" | "salary_change" | "title_change" | "department_change" | "other"
  description String
  oldValue    String?
  newValue    String?
  note        String?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([companyId])
  @@index([employeeId])
}

model Certificate {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  name        String
  issuer      String?
  issueDate   String?  // YYYY-MM-DD
  expiryDate  String?  // YYYY-MM-DD
  note        String?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([companyId])
  @@index([employeeId])
}

model SalaryHistory {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  date        String   // YYYY-MM-DD — ngày áp dụng
  oldSalary   Int
  newSalary   Int
  reason      String?
  adminEmail  String?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([companyId])
  @@index([employeeId])
}

model EarlyLeaveRequest {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  date       String   // YYYY-MM-DD
  leaveTime  String   // HH:MM — giờ muốn về sớm
  reason     String?
  status     String   @default("pending") // "pending" | "approved" | "rejected"
  note       String?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([companyId, status])
  @@index([employeeId])
}

model ShiftSwapRequest {
  id            String   @id @default(cuid())
  companyId     String
  requesterId   String
  targetId      String
  requesterDate String   // YYYY-MM-DD — ngày ca của người xin đổi
  targetDate    String   // YYYY-MM-DD — ngày ca muốn đổi sang
  reason        String?
  status        String   @default("pending") // "pending" | "approved" | "rejected"
  note          String?
  createdAt     DateTime @default(now())

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requester Employee @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target    Employee @relation("SwapTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([requesterId])
  @@index([targetId])
}

// Doanh số / KPI tháng của nhân viên (dùng cho lương commission/KPI)
model SalesRecord {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  month       String   // YYYY-MM
  salesAmount Float    @default(0) // Doanh số thực tế trong tháng
  kpiScore    Float?   // 0–100 điểm KPI (null nếu không dùng KPI scoring)
  note        String?
  createdAt   DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month])
  @@index([companyId, month])
}

// Vị trí tuyển dụng
model JobPosting {
  id           String      @id @default(cuid())
  companyId    String
  title        String
  department   String?
  location     String?
  description  String?
  requirements String?
  salaryMin    Int?
  salaryMax    Int?
  status       String      @default("open") // "open" | "closed" | "filled"
  createdAt    DateTime    @default(now())

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidates Candidate[]

  @@index([companyId, status])
}

// Ứng viên
model Candidate {
  id         String    @id @default(cuid())
  companyId  String
  jobId      String
  name       String
  email      String?
  phone      String?
  status     String    @default("new") // "new" | "reviewing" | "interview" | "offer" | "hired" | "rejected"
  notes      String?
  source     String?   // "website" | "referral" | "linkedin" | "facebook" | "other"
  hiredEmpId String?   // employeeId nếu được tuyển vào làm
  appliedAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job     JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  hiredEmployee Employee? @relation(fields: [hiredEmpId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([jobId])
}

// Bảng tin nội bộ công ty
model Announcement {
  id          String    @id @default(cuid())
  companyId   String
  title       String
  content     String
  type        String    @default("info") // "info" | "warning" | "urgent"
  pinned      Boolean   @default(false)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdBy   String?   // email admin
  createdAt   DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, publishedAt])
}

// Chi phí công tác / Expense claims
model ExpenseClaim {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  title       String
  category    String   @default("other") // "transport" | "meal" | "accommodation" | "entertainment" | "other"
  amount      Int      // VND
  date        String   // YYYY-MM-DD
  description String?
  receiptUrl  String?
  status      String   @default("pending") // "pending" | "approved" | "rejected" | "paid"
  note        String?
  approvedBy  String?  // email admin
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([employeeId])
}

// Đánh giá hiệu suất nhân viên
model PerformanceReview {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  period       String   // e.g. "2026-Q2", "2026-H1", "2026"
  type         String   @default("quarterly") // "monthly" | "quarterly" | "semi-annual" | "annual"
  overallScore Float?   // 1–5 do manager chấm
  selfScore    Float?   // 1–5 do nhân viên tự chấm
  strengths    String?
  improvements String?
  goals        String?
  status       String   @default("pending") // "pending" | "self-review" | "manager-review" | "done"
  reviewedBy   String?  // email admin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, period])
  @@index([companyId, period])
}

// Mẫu checklist onboarding/offboarding
model ChecklistTemplate {
  id        String   @id @default(cuid())
  companyId String
  type      String   // "onboarding" | "offboarding"
  name      String
  tasks     String   // JSON: string[]
  createdAt DateTime @default(now())

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  checklists EmployeeChecklist[]

  @@index([companyId, type])
}

// Checklist gắn với nhân viên cụ thể
model EmployeeChecklist {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  templateId String
  type       String   // "onboarding" | "offboarding"
  tasks      String   // JSON: [{title: string, done: boolean, doneAt: string | null}]
  status     String   @default("in_progress") // "in_progress" | "done"
  dueDate    String?  // YYYY-MM-DD
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([companyId, type])
  @@index([employeeId])
}

// Mẫu lịch ca tuần (để áp dụng nhanh)
model ShiftTemplate {
  id        String   @id @default(cuid())
  companyId String
  name      String   // e.g. "Ca sáng T2-T6"
  pattern   String   // JSON: [{dayOfWeek: 1, shiftId: "..."}] (0=CN, 1=T2...)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// Lưu các code cũ khi affiliate đổi slug — old links vẫn tracking được
model AffiliateCodeHistory {
  id          String    @id @default(cuid())
  affiliateId String
  oldCode     String    @unique
  createdAt   DateTime  @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
}
