{
  "expo": {
    "name": "Timio",
    "slug": "timio",
    "version": "1.4.0",
    "owner": "sinhgiangs-team",
    "extra": {
      "eas": {
        "projectId": "a8f65098-e585-4531-8484-e818afa68746"
      }
    },
    "orientation": "portrait",
    "backgroundColor": "#f9fafb",
    "android": {
      "package": "vn.timio.app"
    },
    "scheme": "timio",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Cho phép Timio dùng micro để bạn nói với trợ lý AI.",
          "speechRecognitionPermission": "Cho phép Timio nhận diện giọng nói để chuyển lời bạn thành câu hỏi."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
